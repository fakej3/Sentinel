# Sentinel — environment variables
# Copy this file to .env.local and adjust values for your setup.
# .env.local is gitignored and never committed.

# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL of the Sentinel API server.
# When running both the Vite dev server and the API locally, set this to the
# API port so the frontend can reach the backend directly.
# If left unset, the Vite proxy forwards /api requests to http://localhost:3000.
VITE_API_URL=http://localhost:3000

# ── Backend ───────────────────────────────────────────────────────────────────

# Port the Sentinel API server listens on. Defaults to 3000.
# PORT=3000

# ── AI Enhancement (optional) ─────────────────────────────────────────────────
# When set, Sentinel enhances the Writer output via AI after the deterministic
# pipeline completes. The application works fully without this key — the
# deterministic Writer is always the fallback.

# Google Gemini API key. Obtain one at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_key_here

# ── Notes ─────────────────────────────────────────────────────────────────────
# Binance market data is fetched from public REST endpoints (no API key needed).
# BINANCE_SPOT_URL defaults to https://api.binance.com
# BINANCE_FUTURES_URL defaults to https://fapi.binance.com
