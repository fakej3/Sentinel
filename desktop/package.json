{
  "name": "sentinel",
  "private": true,
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"API,WEB\" -c \"cyan,blue\" \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:frontend": "vite",
    "start": "NODE_ENV=production tsx src/server.ts",
    "start:api": "NODE_ENV=production tsx src/server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b tsconfig.app.json --noEmit",
    "test": "vitest run && tsc -b tsconfig.app.json --noEmit",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
